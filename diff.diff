+class QuantConfig(ABC):
+    """Abstract base class for quantization configuration in MoE layers."""
+
+    @abstractmethod
+    def should_quantize(self, layer_name: str) -> bool:
+        """Check if a specific layer should use this quantization scheme.
+
+        Args:
+            layer_name: Name of the layer (e.g., "w1", "w2", "w3")
+
+        Returns:
+            True if the layer should be quantized, False otherwise
+        """
+        pass
+
+
+class MXFP8Config(QuantConfig):
+    """Configuration for MXFP8 quantization in MoE layers.
+
+    Args:
+        enabled_layers: Set of layer names to apply mxfp8 to (e.g., {"w1", "w2", "w3"})
+        block_size: Block size for MXFP8 quantization (must be 32)
+        out_dtype: Output dtype for the result
+        kernel_preference: Kernel preference ("auto" or "emulated")
+        wgrad_with_hp: Whether to compute weight gradient in high precision
+        scale_calculation_mode: Mode for scale calculation ("rceil", "floor", etc.)
+    """
+
+    def __init__(
+        self,
+        enabled_layers: set[str] | None = None,
+        block_size: int = 32,
+        out_dtype: torch.dtype = torch.bfloat16,
+        kernel_preference: str = "auto",
+        wgrad_with_hp: bool = False,
+        scale_calculation_mode: str = "rceil",
+    ):
+        self.enabled_layers = enabled_layers if enabled_layers else {"w1", "w2", "w3"}
+        self.block_size = block_size
+        self.out_dtype = out_dtype
+        self.kernel_preference = kernel_preference
+        self.wgrad_with_hp = wgrad_with_hp
+        self.scale_calculation_mode = scale_calculation_mode
+
+    def should_quantize(self, layer_name: str) -> bool:
+        """Check if a specific layer should use mxfp8."""
+        return layer_name in self.enabled_layers
+
+
+def apply_grouped_mm(
+    A: torch.Tensor,
+    B: torch.Tensor,
+    offs: torch.Tensor,
+    quant_config: QuantConfig | None,
+) -> torch.Tensor:
+    """Apply grouped matrix multiplication with optional quantization.
+
+    Args:
+        A: Input tensor, shape (M, K)
+        B: Weight tensor, shape (E, N, K)
+        offs: Offsets tensor for grouped mm
+        quant_config: Quantization configuration (None for no quantization)
+
+    Returns:
+        Output tensor, shape (M, N)
+    """
+    # Extract layer name from parameter metadata
+    layer_name = getattr(B, "_name", None)
+
+    # Transpose B to get (E, K, N) layout
+    B_t = B.transpose(-2, -1)
+
+    # No quantization or layer not enabled for quantization
+    if quant_config is None or not quant_config.should_quantize(layer_name):
+        return torch._grouped_mm(A.bfloat16(), B_t.bfloat16(), offs=offs)
+
+    # Apply quantization based on config type
+    if isinstance(quant_config, MXFP8Config):
+        from torchao.prototype.mx_formats.grouped_mm.mxfp8_grouped_mm import (
+            _to_mxfp8_then_scaled_grouped_mm,
+        )
+        from torchao.prototype.mx_formats.config import ScaleCalculationMode
+        from torchao.quantization.quantize_.common import KernelPreference
+
+        # Map string to enum
+        kernel_pref = KernelPreference(quant_config.kernel_preference.upper())
+        scale_mode = ScaleCalculationMode[quant_config.scale_calculation_mode.upper()]
+        return _to_mxfp8_then_scaled_grouped_mm(
+            A,
+            B_t,
+            offs=offs,
+            block_size=quant_config.block_size,
+            out_dtype=quant_config.out_dtype,
+            kernel_preference=kernel_pref,
+            wgrad_with_hp=quant_config.wgrad_with_hp,
+            scale_calculation_mode=scale_mode,
+        )
+
+    elif isinstance(quant_config, FP8Config):
+        from torchao.float8.grouped_mm import (
+            _to_fp8_rowwise_then_scaled_grouped_mm,
+        )
+        return _to_fp8_rowwise_then_scaled_grouped_mm(
+            A,
+            B_t,
+            offs=offs,
+            out_dtype=quant_config.out_dtype,
+        )
+    else:
+        raise NotImplementedError(
+            f"Quantization config type {type(quant_config).__name__} not supported"
+        )
+
